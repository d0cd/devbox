#!/usr/bin/env bash
# devbox — isolated containerized development environment.
#
# Usage:
#   devbox [project-path]    Start or resume environment (default: current dir)
#   devbox start [path]      Explicitly start a new session
#   devbox resume [name]     Shell into a running session by name
#   devbox stop [name]       Stop a session
#   devbox status            Show running sessions
#   devbox info              Show container status and project info
#   devbox profile [name]    Install a language profile (interactive if no name)
#   devbox allowlist [cmd]   View/edit the network allowlist
#   devbox mount [cmd]       Manage per-project volume mounts
#   devbox secrets [cmd]     Manage API keys and secrets
#   devbox logs              Show recent API calls
#   devbox clean [--all]     Clean project data (--all for everything)
#   devbox rebuild           Rebuild container images
#   devbox update            Pull latest source and rebuild
#   devbox help              Show this help
set -euo pipefail

DEVBOX_VERSION="0.3.0"

# Resolve the directory where devbox itself is installed (follows symlinks).
_devbox_source="${BASH_SOURCE[0]}"
while [ -L "$_devbox_source" ]; do
    _devbox_source="$(readlink "$_devbox_source")"
    [[ "$_devbox_source" != /* ]] && _devbox_source="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$_devbox_source"
done
DEVBOX_ROOT="$(cd "$(dirname "$_devbox_source")" && pwd)"
unset _devbox_source
DEVBOX_DATA="${DEVBOX_DATA:-$HOME/.devbox}"
DEVBOX_CONFIG="${DEVBOX_CONFIG:-$HOME/.config/devbox}"

if [ ! -f "${DEVBOX_ROOT}/lib/ui.sh" ]; then
    echo "FATAL: Cannot resolve devbox installation at $DEVBOX_ROOT" >&2
    exit 1
fi

# Source library modules.
source "${DEVBOX_ROOT}/lib/ui.sh"
source "${DEVBOX_ROOT}/lib/firewall.sh"
source "${DEVBOX_ROOT}/lib/container.sh"
source "${DEVBOX_ROOT}/lib/profile.sh"
source "${DEVBOX_ROOT}/lib/allowlist.sh"
source "${DEVBOX_ROOT}/lib/mount.sh"
source "${DEVBOX_ROOT}/lib/secrets.sh"
source "${DEVBOX_ROOT}/lib/commands.sh"

# Load per-project config (env vars take precedence over .devboxrc).
_load_devboxrc "$(pwd)"

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------

main() {
    # Handle global --quiet flag.
    if [ "${1:-}" = "--quiet" ] || [ "${1:-}" = "-q" ]; then
        export DEVBOX_QUIET=1
        shift
    fi

    local cmd="${1:-}"

    # Commands that require Docker must have the daemon running.
    case "$cmd" in
        help | --help | -h | version | --version | -v | completions | secrets | mount)
            # Help, version, completions, secrets, and mount management never need Docker.
            ;;
        *)
            if ! docker info &>/dev/null; then
                ui_error "Docker is not running. Start Docker and try again."
                exit 1
            fi
            ;;
    esac

    # Handle --help/-h for any subcommand by showing the main help.
    if [ "${2:-}" = "--help" ] || [ "${2:-}" = "-h" ]; then
        cmd_help
        return 0
    fi

    case "$cmd" in
        start)
            shift
            cmd_start "${1:-}"
            ;;
        resume)
            shift
            container_shell "${1:-}"
            ;;
        stop)
            shift
            cmd_stop "${1:-}"
            ;;
        status)
            cmd_status
            ;;
        info)
            shift
            cmd_info "${1:-}"
            ;;
        profile)
            shift
            if [ $# -gt 2 ]; then
                ui_error "Too many arguments. Usage: devbox profile [name] [variant]"
                exit 1
            fi
            cmd_profile "${1:-}" "${2:-}"
            ;;
        allowlist)
            shift
            cmd_allowlist "$@"
            ;;
        mount)
            shift
            cmd_mount "$@"
            ;;
        secrets)
            shift
            cmd_secrets "$@"
            ;;
        logs)
            shift
            cmd_logs "$@"
            ;;
        clean)
            shift
            cmd_clean "${1:-}"
            ;;
        resize)
            shift
            cmd_resize "${1:-}" "${2:-}"
            ;;
        rebuild)
            cmd_rebuild
            ;;
        update)
            cmd_update
            ;;
        help | --help | -h)
            cmd_help
            ;;
        completions)
            # Detect shell and output the appropriate completion script.
            local shell_name="${2:-}"
            if [ -z "$shell_name" ]; then
                shell_name="$(basename "${SHELL:-bash}")"
            fi
            case "$shell_name" in
                bash) cat "${DEVBOX_ROOT}/tooling/completions.bash" ;;
                zsh) cat "${DEVBOX_ROOT}/tooling/completions.zsh" ;;
                *)
                    ui_error "Unsupported shell: '$shell_name'"
                    ui_info "Supported shells: bash, zsh"
                    exit 1
                    ;;
            esac
            ;;
        version | --version | -v)
            echo "devbox v${DEVBOX_VERSION}"
            ;;
        *)
            if [ -z "$cmd" ] || [ -d "$cmd" ]; then
                # No subcommand or a valid directory path — start or resume.
                cmd_start "$cmd"
            else
                ui_error "Unknown command: $cmd"
                ui_info "Run 'devbox help' for available commands."
                exit 1
            fi
            ;;
    esac
}

main "$@"
