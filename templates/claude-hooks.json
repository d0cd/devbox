{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "devbox-status idle; devbox-status notify 'Claude Code' 'Task complete'",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "devbox-status attention; devbox-status notify 'Claude Code' 'Permission needed'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "devbox-status attention; devbox-status notify 'Claude Code' 'Waiting for input'",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "devbox-status working",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
