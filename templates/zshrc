# devbox zsh configuration.
# Sourced inside the agent container. Override via private config overlay.

# Oh My Zsh setup — installed to /opt for read-only rootfs compatibility.
export ZSH="/opt/oh-my-zsh"
ZSH_THEME="robbyrussell"

# Plugins.
plugins=(
    git
    zsh-syntax-highlighting
)

source "$ZSH/oh-my-zsh.sh"

# Simple devbox indicator in prompt.
PROMPT='%F{cyan}[devbox:${DEVBOX_PROJECT:-workspace}]%f %F{green}%~%f $(git_prompt_info)%# '

# Persist shell history to a mounted volume so it survives container restarts.
export HISTFILE=/data/history/.zsh_history
export HISTSIZE=10000
export SAVEHIST=10000

# Default editor.
export EDITOR=nvim
export VISUAL=nvim
alias vi='nvim'
alias vim='nvim'

# Don't store commands with a leading space in history.
setopt HIST_IGNORE_SPACE
