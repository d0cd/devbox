#!/usr/bin/env bash
# Send a message to cmux via the proxy sidecar's /_devbox/ endpoint.
# All traffic routes through the existing proxy — no direct host access.
#
# Usage: devbox-cmux-send notify '{"title":"...","body":"..."}'
#        devbox-cmux-send status 'set_status claude working'
#
# Silently exits 0 if the proxy is unavailable. Safe to call unconditionally.
set -euo pipefail

[ -n "${DEVBOX_CMUX_PROXY_PORT:-}" ] || exit 0

subcmd="${1:-}"
msg="${2:-}"
[ -n "$subcmd" ] || exit 0

case "$subcmd" in
    notify)
        curl -s -o /dev/null -X POST \
            -H "Content-Type: application/json" \
            -d "$msg" \
            "http://proxy:8080/_devbox/notify" 2>/dev/null || true
        ;;
    status)
        curl -s -o /dev/null -X POST \
            -d "$msg" \
            "http://proxy:8080/_devbox/status" 2>/dev/null || true
        ;;
esac
