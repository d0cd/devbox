#!/usr/bin/env bash
# Set cmux sidebar status and send notifications via the proxy sidecar.
# All communication routes through http://proxy:8080/_devbox/ — no direct host access.
#
# Usage:
#   devbox-status set <key> <value>
#   devbox-status clear <key>
#   devbox-status notify <title> <body>
#   devbox-status working           Shorthand: set claude to working state
#   devbox-status idle              Shorthand: set claude to idle state
#   devbox-status attention         Shorthand: set claude to needs-input state
set -euo pipefail

cmd="${1:-}"
shift || true

case "$cmd" in
    set)
        key="${1:-}"
        value="${2:-}"
        [ -n "$key" ] && [ -n "$value" ] || exit 0
        shift 2 || true
        devbox-cmux-send status "set_status $key $value $*"
        ;;
    clear)
        key="${1:-}"
        [ -n "$key" ] || exit 0
        devbox-cmux-send status "clear_status $key"
        ;;
    notify)
        title="${1:-devbox}"
        body="${2:-}"
        # Escape for JSON.
        title="${title//\\/\\\\}"
        title="${title//\"/\\\"}"
        body="${body//\\/\\\\}"
        body="${body//\"/\\\"}"
        devbox-cmux-send notify "{\"title\":\"$title\",\"body\":\"$body\"}"
        ;;
    working)
        devbox-cmux-send status "set_status claude Working --icon=bolt.fill --color=#4C8DFF"
        ;;
    idle)
        devbox-cmux-send status "set_status claude Idle --icon=pause.circle.fill --color=#8E8E93"
        ;;
    attention)
        devbox-cmux-send status "set_status claude 'Needs input' --icon=bell.fill --color=#FF9F0A"
        ;;
    *)
        exit 0
        ;;
esac
